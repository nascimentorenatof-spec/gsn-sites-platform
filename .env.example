# =============================================
# Variáveis de ambiente do Getsitesninjas
# =============================================
# Esse arquivo é só um EXEMPLO. Não coloque chaves reais aqui.
# Copie pra .env.local pra rodar local OU configure direto na Vercel
# em: Settings → Environment Variables.
# =============================================

# Chave da Anthropic (Claude). Pegar em: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=sk-ant-api03-XXXXX

# Token do PagSeguro/PagBank. Pegar em: https://acesso.pagseguro.uol.com.br/integration
# Use sandbox enquanto testa, depois troca pra produção.
PAGSEGURO_TOKEN=
PAGSEGURO_ENV=sandbox

# Senha do painel admin (/admin.html). Use uma senha forte.
ADMIN_SENHA=trocar-esta-senha-ja

# Banco de dados (Upstash Redis) — injetadas automaticamente pelo Vercel
# quando você conecta um Upstash via Marketplace. Não precisa preencher manual.
KV_REST_API_URL=
KV_REST_API_TOKEN=
